# Required: Resend API key for the contact form (https://resend.com)
RESEND_API_KEY=

# Optional: from address. Defaults to Resend's sandbox sender
# (Portfolio <onboarding@resend.dev>). Replace with an address on a
# verified domain once you've verified one in Resend.
CONTACT_FROM_EMAIL=

# Optional: where contact-form messages are delivered.
# Defaults to moussa.abdelghany@gmail.com.
CONTACT_TO_EMAIL=
